<Window x:Class="RoboCopyGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:RoboCopyGUI.Converters"
        Title="RoboCopy 文件拷贝工具"
        Width="900" Height="880"
        MinWidth="760" MinHeight="700"
        Background="{StaticResource BgDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Segoe UI, Segoe UI Emoji"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:BrushKeyConverter x:Key="BrushKey" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,14,20,14">

                <!-- ============ 标题 ============ -->
                <TextBlock Text="RoboCopy 文件拷贝工具" FontSize="24" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="把文件从一个文件夹复制到另一个，三步搞定"
                           FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,4,0,12" />

                <!-- ============ 第 1 步：选择文件夹 ============ -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Style="{StaticResource StepTitle}" Text="第 1 步 · 选择文件夹" />

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📂 源文件夹（从这里复制）" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                <TextBox x:Name="SourcePathBox"
                                         Text="{Binding SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AllowDrop="True"
                                         PreviewDragOver="PathBox_PreviewDragOver"
                                         Drop="SourcePathBox_Drop" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="浏览..."
                                    Style="{StaticResource SecondaryButton}"
                                    VerticalAlignment="Bottom" Height="35"
                                    Margin="8,0,0,0"
                                    Command="{Binding BrowseSourceCommand}" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="📁 目标位置（复制到这里）" FontSize="13"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6" />
                                <TextBox x:Name="DestPathBox"
                                         Text="{Binding DestPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AllowDrop="True"
                                         PreviewDragOver="PathBox_PreviewDragOver"
                                         Drop="DestPathBox_Drop" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="浏览..."
                                    Style="{StaticResource SecondaryButton}"
                                    VerticalAlignment="Bottom" Height="35"
                                    Margin="8,0,0,0"
                                    Command="{Binding BrowseDestCommand}" />
                        </Grid>

                        <TextBlock Text="💡 也可以直接把文件夹拖到输入框里"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,10,0,0" />

                        <CheckBox x:Name="IncludeSourceFolderCheck"
                                  Content="📂 目标保留源文件夹名（复制到 dest\source\ 而不是 dest\）"
                                  IsChecked="{Binding IncludeSourceFolderName, Mode=TwoWay}"
                                  FontSize="12"
                                  Margin="0,10,0,0" />
                    </StackPanel>
                </Border>

                <!-- ============ 第 2 步：场景卡片 ============ -->
                <Border x:Name="Step2Card" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                    <StackPanel>
                        <!-- 拷贝中的折叠摘要 -->
                        <TextBlock x:Name="ScenarioSummary"
                                   Text="{Binding ScenarioSummary}"
                                   Visibility="{Binding ScenarioSummaryVisible, Converter={StaticResource BoolToVis}}"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" />

                        <StackPanel x:Name="ScenarioFullPanel"
                                    Visibility="{Binding ScenarioFullVisible, Converter={StaticResource BoolToVis}}">
                            <TextBlock Style="{StaticResource StepTitle}" Text="第 2 步 · 你想做什么？" />

                            <UniformGrid Columns="4">
                                <RadioButton x:Name="Card0" Style="{StaticResource ScenarioCard}"
                                             GroupName="Scenario" Checked="ScenarioCard_Checked" />
                                <RadioButton x:Name="Card1" Style="{StaticResource ScenarioCard}"
                                             GroupName="Scenario" Checked="ScenarioCard_Checked" />
                                <RadioButton x:Name="Card2" Style="{StaticResource ScenarioCard}"
                                             GroupName="Scenario" Checked="ScenarioCard_Checked" />
                                <RadioButton x:Name="Card3" Style="{StaticResource ScenarioCard}"
                                             GroupName="Scenario" Checked="ScenarioCard_Checked" />
                            </UniformGrid>

                            <!-- 完全同步警告 -->
                            <Border x:Name="MirrorWarning"
                                    Visibility="{Binding MirrorWarningVisible, Converter={StaticResource BoolToVis}}"
                                    Background="{StaticResource WarningSoftBrush}"
                                    CornerRadius="6" Padding="10,8" Margin="6,10,6,0">
                                <TextBlock FontSize="12" Foreground="{StaticResource WarningBrush}"
                                           Text="⚠ 完全同步会删除目标文件夹里多出来的文件，请确认目标文件夹里没有重要数据" />
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ============ 第 3 步：开始 ============ -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="StartBtn"
                            Content="▶  开 始 复 制"
                            Style="{StaticResource PrimaryButton}"
                            Height="52"
                            Command="{Binding StartCopyCommand}"
                            IsEnabled="{Binding StartBtnEnabled}" />
                    <Button Grid.Column="1" x:Name="CancelBtn"
                            Content="取消"
                            Style="{StaticResource SecondaryButton}"
                            Height="52" MinWidth="90" Margin="10,0,0,0"
                            Visibility="{Binding CancelBtnVisible, Converter={StaticResource BoolToVis}}"
                            Command="{Binding CancelCopyCommand}" />
                </Grid>

                <!-- ============ 进度 / 结果卡片 ============ -->
                <Border x:Name="ProgressCard" Style="{StaticResource CardBorder}"
                        Visibility="{Binding ProgressCardVisible, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,10">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="StatusHeader"
                                       Text="{Binding StatusHeader}"
                                       FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" x:Name="ProgressPercent"
                                       Text="{Binding ProgressPercent}"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{StaticResource AccentLightBrush}" />
                        </Grid>

                        <ProgressBar x:Name="CopyProgressBar"
                                     Value="{Binding ProgressValue}"
                                     Margin="0,0,0,10" />

                        <TextBlock x:Name="ProgressFiles"
                                   Text="{Binding ProgressFiles}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBlock x:Name="ProgressBytes"
                                   Text="{Binding ProgressBytes}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />
                        <TextBlock x:Name="ProgressSpeed"
                                   Text="{Binding ProgressSpeed}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />
                        <TextBlock x:Name="ProgressTime"
                                   Text="{Binding ProgressTime}"
                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,2,0,0" />
                        <TextBlock x:Name="ProgressFile"
                                   Text="{Binding ProgressFile}"
                                   FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,6,0,0" />

                        <!-- 结果区 -->
                        <StackPanel x:Name="ResultPanel"
                                    Visibility="{Binding ResultVisible, Converter={StaticResource BoolToVis}}"
                                    Margin="0,14,0,0">
                            <Border Background="{StaticResource BgInputBrush}"
                                    CornerRadius="8" Padding="14,12">
                                <StackPanel Orientation="Horizontal">
                                    <Border x:Name="ResultBadge" Width="44" Height="44" CornerRadius="22"
                                            Background="{Binding ResultBadgeBrushKey, Converter={StaticResource BrushKey}}"
                                            VerticalAlignment="Center" Margin="0,0,12,0">
                                        <TextBlock x:Name="ResultIcon"
                                                   Text="{Binding ResultIcon}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="White"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock x:Name="ResultTitle"
                                                   Text="{Binding ResultTitle}"
                                                   FontSize="15" FontWeight="SemiBold" />
                                        <TextBlock x:Name="ResultSummary"
                                                   Text="{Binding ResultSummary}"
                                                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,4,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                            <Button x:Name="OpenDestBtn" Content="📂 打开目标文件夹"
                                    Style="{StaticResource SecondaryButton}"
                                    HorizontalAlignment="Left"
                                    Margin="0,10,0,0"
                                    Command="{Binding OpenDestCommand}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ============ 高级设置（折叠） ============ -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="8">
                    <Expander Header="高级设置（技术参数，不懂不用动）">
                        <WrapPanel Margin="8,4,8,4">
                            <CheckBox x:Name="MultiThreadCheck" Content="多线程 /MT" Margin="0,0,16,8"
                                      IsChecked="{Binding MultiThread, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />
                            <TextBox x:Name="ThreadCountBox"
                                     Text="{Binding ThreadCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="64" Margin="0,0,24,8"
                                     HorizontalContentAlignment="Center" ToolTip="线程数 1-128"
                                     PreviewTextInput="NumberOnly_Preview"
                                     DataObject.Pasting="NumberOnly_Pasting" />

                            <CheckBox x:Name="MirrorCheck" Content="镜像 /MIR" Margin="0,0,16,8"
                                      IsChecked="{Binding Mirror, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />
                            <CheckBox x:Name="SubdirsCheck" Content="子目录 /E" Margin="0,0,16,8"
                                      IsChecked="{Binding IncludeSubdirs, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />
                            <CheckBox x:Name="RestartCheck" Content="断点续传 /Z" Margin="0,0,16,8"
                                      IsChecked="{Binding RestartMode, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />

                            <TextBlock Text="重试 /R:" VerticalAlignment="Center" Margin="0,0,4,8"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBox x:Name="RetryCountBox"
                                     Text="{Binding RetryCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="48" Margin="0,0,12,8"
                                     HorizontalContentAlignment="Center"
                                     PreviewTextInput="NumberOnly_Preview"
                                     DataObject.Pasting="NumberOnly_Pasting" />

                            <TextBlock Text="等待 /W:" VerticalAlignment="Center" Margin="0,0,4,8"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                            <TextBox x:Name="RetryWaitBox"
                                     Text="{Binding RetryWait, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="48" Margin="0,0,16,8"
                                     HorizontalContentAlignment="Center"
                                     PreviewTextInput="NumberOnly_Preview"
                                     DataObject.Pasting="NumberOnly_Pasting" />

                            <CheckBox x:Name="CopyAllCheck" Content="权限 /COPYALL" Margin="0,0,16,8"
                                      IsChecked="{Binding CopyAll, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />
                            <CheckBox x:Name="DirTimeCheck" Content="目录时间戳 /DCOPY:T" Margin="0,0,16,8"
                                      IsChecked="{Binding CopyDirTimestamps, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />
                            <CheckBox x:Name="VerboseCheck" Content="详细日志 /V" Margin="0,0,0,8"
                                      IsChecked="{Binding Verbose, Mode=TwoWay}"
                                      Checked="ParamChanged" Unchecked="ParamChanged" />
                        </WrapPanel>
                    </Expander>
                </Border>

                <!-- ============ 详细日志（折叠） ============ -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,10" Padding="8">
                    <Expander x:Name="LogExpander" Header="详细日志（技术人员排查用）">
                        <Border Background="{StaticResource BgInputBrush}"
                                CornerRadius="6" Padding="8" Margin="8,4,8,4" Height="160">
                            <ScrollViewer x:Name="LogScrollView" VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="LogBox"
                                         Text="{Binding LogText, Mode=OneWay}"
                                         Background="Transparent" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="12"
                                         Foreground="{StaticResource TextSecondaryBrush}"
                                         IsReadOnly="True" TextWrapping="Wrap" />
                            </ScrollViewer>
                        </Border>
                    </Expander>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- ============ 状态栏 ============ -->
        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}"
                Padding="14,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse x:Name="StatusDot" Width="8" Height="8"
                         Fill="{Binding StatusDotBrushKey, Converter={StaticResource BrushKey}}"
                         VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBlock x:Name="StatusText"
                           Text="{Binding StatusText}"
                           FontSize="12" Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
